# Future audio/voice client configuration
# This repository is a client of hue-local-api.
# Do not place Hue Bridge credentials here.

# Required for calling hue-local-api
HUE_LOCAL_API_BASE_URL=http://127.0.0.1:8000
HUE_LOCAL_API_KEY=replace-with-local-api-key

# Recommended client-side HTTP behavior
HUE_LOCAL_API_TIMEOUT_MS=5000

# Suggested clap-detection settings for the future audio client
# These are product-side settings, not values read by hue-local-api.
CLAP_REQUIRED_COUNT=2
CLAP_WINDOW_MS=3000
CLAP_COOLDOWN_MS=1500

# Suggested future voice settings
VOICE_LANGUAGE=fr-FR
VOICE_WAKE_PREFIX=Philips

# Suggested audio input selection
AUDIO_INPUT_DEVICE_ID=default

# Optional initial target light for prototypes
# Prefer a discovered/configured light ID over a hardcoded value in production.
DEFAULT_LIGHT_ID=light-1
